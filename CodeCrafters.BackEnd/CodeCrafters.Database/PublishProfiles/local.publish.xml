<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <!-- Local development publish profile for SQL Server LocalDB -->
    <TargetConnectionString>Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=CodeCrafters_Local;Integrated Security=True;Encrypt=False</TargetConnectionString>
    <ProfileName>Local</ProfileName>
    <IncludeCompositeObjects>True</IncludeCompositeObjects>
    <BlockOnPossibleDataLoss>False</BlockOnPossibleDataLoss>
    <ScriptDatabaseOptions>False</ScriptDatabaseOptions>
  </PropertyGroup>
</Project>

